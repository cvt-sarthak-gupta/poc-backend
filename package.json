{
  "name": "pip-backend",
  "version": "1.0.0",
  "description": "Multi-tenant Orders Aggregation POC — Express 5, TypeORM, PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate:admin": "f() { npm run typeorm -- migration:generate src/admin/migrations/$1 -d src/infrastructure/database/admin.datasource.ts; }; f",
    "migration:generate:tenant": "f() { npm run typeorm -- migration:generate src/tenants/migrations/$1 -d src/infrastructure/database/tenant.datasource.ts; }; f",
    "migration:run:admin": "npm run typeorm -- migration:run -d src/infrastructure/database/admin.datasource.ts",
    "migration:run:tenant": "npm run typeorm -- migration:run -d src/infrastructure/database/tenant.datasource.ts",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^7.18.0"
  }
}
